<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Book Notes</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <h1>Book Notes</h1>

  <h2>Add a Book</h2>
  <form action="/add" method="POST" class="card">
    <input name="title" placeholder="Title" required />
    <input name="author" placeholder="Author" />
    <input name="isbn" placeholder="ISBN (for cover)" />
    <input name="rating" type="number" min="1" max="5" placeholder="Rating (1-5)" />
    <input name="date_read" type="date" />
    <textarea name="notes" placeholder="Your notes..."></textarea>
    <button type="submit">Add</button>
  </form>

  <h2>Your Books</h2>

  <% if (books.length === 0) { %>
    <p>No books yet.</p>
  <% } %>

  <div class="grid">
    <% books.forEach((b) => { %>
      <div class="book card">
        <% if (b.isbn) { %>
          <img src="https://covers.openlibrary.org/b/isbn/<%= b.isbn %>-M.jpg?default=false"
               onerror="this.style.display='none'" />
        <% } %>

        <h3><%= b.title %></h3>
        <p><strong>Author:</strong> <%= b.author || "—" %></p>
        <p><strong>Rating:</strong> <%= b.rating || "—" %></p>
        <p><strong>Date Read:</strong> <%= b.date_read ? String(b.date_read).slice(0,10) : "—" %></p>

        <% if (b.notes) { %>
          <p class="notes"><%= b.notes %></p>
        <% } %>

        <form action="/delete" method="POST">
          <input type="hidden" name="id" value="<%= b.id %>" />
          <button type="submit">Delete</button>
        </form>
      </div>
    <% }); %>
  </div>
</body>
</html>
